rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: trips
    // Document ID: auto-generated
    // Fields:
    //   - trip_name: string (required, 1-100 chars)
    //   - user_email: string (required, immutable) - Owner's email
    //   - budget: map (required)
    //     - accommodation: number (positive)
    //     - transport: number (positive)
    //     - food_activities: number (positive)
    //     - shopping: number (positive)
    //     - miscellaneous: number (positive)
    //   - created_at: timestamp (required, immutable)
    //
    // Collection: trips/{tripId}/expenses
    // Document ID: auto-generated
    // Fields:
    //   - date: timestamp (required)
    //   - category: string (required, enum)
    //   - amount_inr: number (required, positive)
    //   - notes: string (optional, max 500 chars)
    //   - created_at: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isValidTrip(data) {
      return data.trip_name is string && data.trip_name.size() >= 1 && data.trip_name.size() <= 100 &&
             data.user_email is string &&
             data.budget is map &&
             data.budget.accommodation is number && data.budget.accommodation >= 0 &&
             data.budget.transport is number && data.budget.transport >= 0 &&
             data.budget.food_activities is number && data.budget.food_activities >= 0 &&
             data.budget.shopping is number && data.budget.shopping >= 0 &&
             data.budget.miscellaneous is number && data.budget.miscellaneous >= 0;
    }

    function isValidExpense(data) {
      let categories = ['accommodation', 'transport', 'food_activities', 'shopping', 'miscellaneous'];
      return data.date is timestamp &&
             data.category in categories &&
             data.amount_inr is number && data.amount_inr >= 0 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 500));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dmanji@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /trips/{tripId} {
      allow read: if isOwner(resource.data.user_email) || isAdmin();
      
      allow create: if isAuthenticated() && 
                      isValidTrip(request.resource.data) && 
                      request.resource.data.user_email == request.auth.token.email;
      
      allow update: if isOwner(resource.data.user_email) && 
                      isValidTrip(request.resource.data) &&
                      request.resource.data.user_email == resource.data.user_email &&
                      request.resource.data.created_at == resource.data.created_at;
      
      allow delete: if isOwner(resource.data.user_email) || isAdmin();

      match /expenses/{expenseId} {
        allow read: if isOwner(get(/databases/$(database)/documents/trips/$(tripId)).data.user_email) || isAdmin();
        
        allow create: if isOwner(get(/databases/$(database)/documents/trips/$(tripId)).data.user_email) && 
                        isValidExpense(request.resource.data);
        
        allow update: if isOwner(get(/databases/$(database)/documents/trips/$(tripId)).data.user_email) && 
                        isValidExpense(request.resource.data) &&
                        request.resource.data.created_at == resource.data.created_at;
        
        allow delete: if isOwner(get(/databases/$(database)/documents/trips/$(tripId)).data.user_email) || isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
